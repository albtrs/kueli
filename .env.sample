## Required (dev/prod)
JWT_SECRET=change-me

## Optional (API defaults)
# DATABASE_PATH=./data/db/app.db
# UPLOADS_DIR=./data/uploads

## Optional (token lifetimes)
# ACCESS_TOKEN_TTL=15m
# REFRESH_TOKEN_TTL=720h

## Optional (production cookies)
# - Leave COOKIE_DOMAIN empty for host-only cookies (usually fine).
# - Set when you need to share cookies across subdomains (e.g. .yamiusa.com).
# COOKIE_DOMAIN=kueli.yamiusa.com
# COOKIE_SECURE=true

## Dev only (Vite proxy)
# VITE_API_INTERNAL_ORIGIN=http://api:8080
# VITE_API_ORIGIN=http://localhost:8081
